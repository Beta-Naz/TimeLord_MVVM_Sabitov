<Page x:Class="TimeLord_MVVM_Сабитов.Views.Timer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TimeLord_MVVM_Сабитов.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Timer">

    <Grid Background="#FFE8E100" DataContext="{Binding Timer}">
        <TextBox Foreground="White" FontSize="48" Text="{Binding TimerString, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
               Margin="115,10,10,10" HorizontalContentAlignment="Center" MaxLength="8" 
                 VerticalContentAlignment="Center" Background="Transparent"/>
        <Button Content="{Binding TextButton, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" 
                VerticalAlignment="Top" Width="100" Height="25" Background="White" Margin="10,10,0,0" Command="{Binding StartTimer}"/>
        <Button Content="Таймер" HorizontalAlignment="Right" VerticalAlignment="Top" Width="100" 
        Height="25" Background="White" Margin="0,10,10,0" Command="{Binding GoToStopwatch}"/>
    </Grid>
</Page>
